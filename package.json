{
  "name": "scholars-syndicate-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Scholars Syndicate - JAMB & Post-UTME Practice Platform with Tokens, Voice AI, Tour Guide, Share Cards, Streak Calendar & Push Notifications",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "avr8js": "^0.20.1",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "socket.io-client": "^4.7.2",
    "web-vitals": "^3.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react-hooks/exhaustive-deps": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
